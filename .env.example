# RareBits Frontend Environment (Production-safe template)
# Copy to .env for local/dev and fill with your real values.

# Supabase project URL (no trailing slash)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/publishable key
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Keep verbose logs off in production build.
# Set to true only for temporary debugging.
VITE_ENABLE_DEBUG_LOGS=false
